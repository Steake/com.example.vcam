<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 13+ scoped media permissions (optional; we rely mostly on Photo Picker / GetContent) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Required on Android 11+ so the manager can actually write the hook's expected files
         under /sdcard/DCIM/Camera1/. Users must grant this once via system settings. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <!-- Camera permission is required by the in-manager verifier activity
         (CameraVerifyActivity) which opens the device camera so the user
         can confirm the hook replaces live preview / still captures. The
         hook itself runs in target processes and does not rely on this. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Signature-level permission for the module/manager to guard
         privileged entry points. The injected-config activity itself is
         exported without this permission so that the in-host hook can
         launch it from a notification (PendingIntent is constructed in the
         host process), which would otherwise be dropped by the platform. -->
    <permission
        android:name="com.example.vcam.permission.CONFIGURE"
        android:protectionLevel="signature" />
    <uses-permission android:name="com.example.vcam.permission.CONFIGURE" />

    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.GET_CONTENT" />
            <data android:mimeType="image/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.GET_CONTENT" />
            <data android:mimeType="video/*" />
        </intent>
    </queries>

    <application
        android:name=".VCAMApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VCAM">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.VCAM">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.VCAM" />

        <activity
            android:name=".InjectedConfigActivity"
            android:exported="true"
            android:label="@string/injected_title"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.VCAM.Translucent">
            <!--
                Exported so that the in-host VCAM hook can launch this activity
                via a PendingIntent attached to the per-app "pick another
                image" notification. The PendingIntent is constructed in the
                host process, so without android:exported="true" the platform
                drops the launch on Android 10+.
                The intent-filter makes implicit launches robust even when the
                ComponentName cannot be resolved (e.g. if the manager is
                obfuscated by LSPosed). We deliberately do NOT guard with a
                signature permission here because the caller is the host
                process, which is never signed by us.
            -->
            <intent-filter>
                <action android:name="com.example.vcam.action.OPEN_INJECTED_CONFIG" />
                <action android:name="com.example.vcam.action.CONFIGURE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".CameraVerifyActivity"
            android:exported="false"
            android:label="@string/verify_camera_title"
            android:theme="@style/Theme.VCAM" />

        <!--
            Exposes the manager's staged image / video so the hook running in
            a host process can stream bytes even when the host has no storage
            permission. See MediaProvider and HookMain#stageFromProvider.
            Exported with no read permission because the staged media is the
            user's own injected content, not sensitive; scoped storage makes
            any other distribution path prohibitively fragile.
        -->
        <provider
            android:name=".MediaProvider"
            android:authorities="com.example.vcam"
            android:exported="true"
            android:grantUriPermissions="true" />

        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="@string/xposed_description" />
        <meta-data
            android:name="xposedminversion"
            android:value="51" />
    </application>

</manifest>
